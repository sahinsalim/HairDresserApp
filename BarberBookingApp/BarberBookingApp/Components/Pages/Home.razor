@code {
    private List<ServiceType>? services;
    private List<WorkingHour> workingHours = new();
    private string WorkingHoursSummary => BuildWorkingHoursSummary();

    protected override async Task OnInitializedAsync()
    {
        services = await Db.ServiceTypes
            .Where(s => s.IsActive)
            .OrderBy(s => s.SortOrder)
            .ToListAsync();

        workingHours = await Db.WorkingHours
            .OrderBy(w => w.DayOfWeek == DayOfWeek.Sunday ? 7 : (int)w.DayOfWeek)
            .ToListAsync();
    }

    private string BuildWorkingHoursSummary()
    {
        var openDays = workingHours.Where(w => w.IsOpen).ToList();
        if (openDays.Count == 0)
        {
            return "Şu anda kapalı";
        }

        var first = openDays[0];
        var sameHours = openDays.All(w => w.StartTime == first.StartTime && w.EndTime == first.EndTime);
        var closedDays = workingHours.Where(w => !w.IsOpen).Select(w => TurkceGun(w.DayOfWeek)).ToList();

        if (sameHours)
        {
            var closedText = closedDays.Count == 0 ? "Her gün" : $"{string.Join(", ", closedDays)} hariç";
            return $"{closedText}<br />{first.StartTime:hh\\:mm} - {first.EndTime:hh\\:mm}";
        }

        return string.Join("<br />", openDays.Take(3)
            .Select(w => $"{TurkceGun(w.DayOfWeek)} {w.StartTime:hh\\:mm} - {w.EndTime:hh\\:mm}"));
    }

    private static string TurkceGun(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Pazartesi",
        DayOfWeek.Tuesday => "Salı",
        DayOfWeek.Wednesday => "Çarşamba",
        DayOfWeek.Thursday => "Perşembe",
        DayOfWeek.Friday => "Cuma",
        DayOfWeek.Saturday => "Cumartesi",
        DayOfWeek.Sunday => "Pazar",
        _ => day.ToString()
    };
}
