@page "/randevu-al"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Customer")]
@inject AppDbContext Db
@inject IAppointmentService AppointmentService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Randevu Al | Kuaför Arif</PageTitle>

<section class="ka-section">
    <div class="container" style="max-width:820px;">
        <div class="ka-section-title">
            <div class="ka-kicker">Randevu</div>
            <div class="divider-gold"></div>
            <h2>Randevunuzu Oluşturun</h2>
        </div>

        @if (success)
        {
            <div class="ka-form-card text-center">
                <i class="bi bi-check-circle text-gold" style="font-size:3.5rem;"></i>
                <h4 class="mt-3">Randevunuz Oluşturuldu!</h4>
                <p class="text-muted">
                    @createdAppointment?.StartTime.ToString("dd MMMM yyyy, dddd HH:mm", new System.Globalization.CultureInfo("tr-TR")) - @DisplayServices(createdAppointment)
                </p>
                <p class="text-muted small">Randevu bilgileriniz işletmeye iletildi. Dilerseniz randevularım ekranından takip edebilirsiniz.</p>
                <a href="/randevularim" class="btn btn-gold mt-2">Randevularımı Gör</a>
            </div>
        }
        else
        {
            <div class="ka-form-card">
                <h5 class="mb-3"><span class="text-gold">1.</span> Hizmetleri Seçin</h5>
                @if (serviceTypes is null)
                {
                    <p class="text-muted">Yükleniyor...</p>
                }
                else
                {
                    <div class="row gy-3 mb-4">
                        @foreach (var s in serviceTypes)
                        {
                            <div class="col-6 col-md-3">
                                <div class="ka-service-option text-center @(selectedServiceIds.Contains(s.Id) ? "selected" : "")"
                                     @onclick="() => ToggleService(s.Id)">
                                    <i class="@s.Icon text-gold fs-4"></i>
                                    <div class="fw-semibold small mt-1">@s.Name</div>
                                </div>
                            </div>
                        }
                    </div>
                    @if (selectedServices.Count > 0)
                    {
                        <div class="alert alert-info small">
                            Seçilenler: <strong>@string.Join(" + ", selectedServices.Select(s => s.Name))</strong>
                        </div>
                    }
                }

                <h5 class="mb-3"><span class="text-gold">2.</span> Tarih Seçin</h5>
                <div class="mb-4" style="max-width:260px;">
                    <input type="date" class="form-control" value="@selectedDate.ToString("yyyy-MM-dd")"
                           min="@minDate.ToString("yyyy-MM-dd")" max="@maxDate.ToString("yyyy-MM-dd")"
                           @onchange="OnDateChanged" />
                    <small class="text-muted">Randevular en fazla @((maxDate.DayNumber - minDate.DayNumber)) gün sonrasına kadar alınabilir.</small>
                </div>

                <h5 class="mb-3"><span class="text-gold">3.</span> Saat Seçin</h5>
                @if (selectedServiceIds.Count == 0)
                {
                    <p class="text-muted small">Lütfen önce en az bir hizmet seçin.</p>
                }
                else if (loadingSlots)
                {
                    <p class="text-muted small">Müsait saatler yükleniyor...</p>
                }
                else if (availableSlots.Count == 0)
                {
                    <div class="alert alert-warning small">Seçilen tarihte müsait saat bulunmuyor. Lütfen başka bir tarih deneyin.</div>
                }
                else
                {
                    <div class="ka-slot-grid mb-4">
                        @foreach (var slot in availableSlots)
                        {
                            <button type="button" class="ka-slot-btn @(selectedSlot == slot ? "selected" : "")"
                                    @onclick="() => selectedSlot = slot">
                                @slot.ToString(@"hh\:mm")
                            </button>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger small">@errorMessage</div>
                }

                <button class="btn btn-gold w-100 mt-2" disabled="@(!CanSubmit || submitting)" @onclick="SubmitAppointment">
                    @(submitting ? "Oluşturuluyor..." : "Randevuyu Onayla")
                </button>
            </div>
        }
    </div>
</section>

@code {
    private List<ServiceType>? serviceTypes;
    private HashSet<int> selectedServiceIds = new();
    private List<ServiceType> selectedServices = new();
    private int combinedDurationMinutes;
    private DateOnly minDate;
    private DateOnly maxDate;
    private DateOnly selectedDate;
    private List<TimeSpan> availableSlots = new();
    private TimeSpan? selectedSlot;
    private bool loadingSlots;
    private bool submitting;
    private bool success;
    private string? errorMessage;
    private Appointment? createdAppointment;

    private bool CanSubmit => selectedServiceIds.Count > 0 && selectedSlot is not null;

    protected override async Task OnInitializedAsync()
    {
        minDate = AppointmentService.GetMinBookingDate();
        maxDate = AppointmentService.GetMaxBookingDate();
        selectedDate = minDate;

        serviceTypes = await Db.ServiceTypes
            .Where(s => s.IsActive)
            .OrderBy(s => s.SortOrder)
            .ToListAsync();
    }

    private async Task ToggleService(int id)
    {
        if (!selectedServiceIds.Add(id))
        {
            selectedServiceIds.Remove(id);
        }

        selectedServices = serviceTypes?
            .Where(s => selectedServiceIds.Contains(s.Id))
            .OrderBy(s => s.SortOrder)
            .ToList() ?? new();
        combinedDurationMinutes = CalculateCombinedDurationMinutes(selectedServices);
        selectedSlot = null;
        await LoadSlots();
    }

    private async Task OnDateChanged(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
        {
            selectedDate = date;
            selectedSlot = null;
            await LoadSlots();
        }
    }

    private async Task LoadSlots()
    {
        if (selectedServiceIds.Count == 0)
        {
            availableSlots = new();
            return;
        }

        loadingSlots = true;
        errorMessage = null;
        availableSlots = await AppointmentService.GetAvailableSlotsAsync(selectedDate, selectedServiceIds.ToList());
        loadingSlots = false;
    }

    private async Task SubmitAppointment()
    {
        if (!CanSubmit)
        {
            return;
        }

        submitting = true;
        errorMessage = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var customerIdClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (customerIdClaim is null || !int.TryParse(customerIdClaim.Value, out var customerId))
        {
            errorMessage = "Oturum bilgisi bulunamadı, lütfen tekrar giriş yapın.";
            submitting = false;
            return;
        }

        var startTime = selectedDate.ToDateTime(TimeOnly.FromTimeSpan(selectedSlot!.Value));
        var result = await AppointmentService.CreateAppointmentAsync(customerId, selectedServiceIds.ToList(), startTime);

        submitting = false;

        if (!result.Success)
        {
            errorMessage = result.ErrorMessage;
            await LoadSlots();
            return;
        }

        createdAppointment = result.Appointment;
        if (createdAppointment is not null)
        {
            createdAppointment.ServiceItems = selectedServices
                .Select(s => new AppointmentServiceItem { ServiceType = s })
                .ToList();
        }
        success = true;
    }

    private static int CalculateCombinedDurationMinutes(IReadOnlyCollection<ServiceType> services)
    {
        if (services.Count == 0)
        {
            return 0;
        }

        var durations = services.Select(s => s.DurationMinutes).OrderByDescending(d => d).ToList();
        var total = durations[0] + durations.Skip(1).Sum(d => d / 2.0);
        return (int)(Math.Ceiling(total / 5.0) * 5);
    }

    private static string DisplayServices(Appointment? appointment)
    {
        if (appointment is null)
        {
            return string.Empty;
        }

        if (appointment.ServiceItems.Count > 0)
        {
            return string.Join(" + ", appointment.ServiceItems
                .Where(i => i.ServiceType is not null)
                .Select(i => i.ServiceType!.Name));
        }

        return appointment.ServiceType?.Name ?? string.Empty;
    }
}
