@page "/iletisim"
@rendermode InteractiveServer
@inject AppDbContext Db

<PageTitle>İletişim | Kuaför Arif</PageTitle>

<section class="ka-hero py-5">
    <div class="container text-center">
        <span class="ka-hero-badge">İletişim</span>
        <h1>Bize Ulaşın</h1>
        <p class="lead mx-auto" style="max-width:700px;">
            Sorularınız için bizi arayabilir veya aşağıdaki formu doldurabilirsiniz.
        </p>
    </div>
</section>

<section class="ka-section">
    <div class="container">
        <div class="row gy-4 align-items-start">
            <div class="col-lg-5">
                <div class="ka-card p-4 mb-4">
                    <h5 class="text-gold mb-3"><i class="bi bi-geo-alt me-2"></i>Adres</h5>
                    <p class="text-muted mb-3">Cumhuriyet Mahallesi, Esenyurt / İstanbul</p>
                    <div class="ka-map-frame">
                        <iframe src="https://www.google.com/maps?q=Cumhuriyet+Mahallesi,+Esenyurt,+%C4%B0stanbul,+T%C3%BCrkiye&output=embed"
                                loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Harita"></iframe>
                    </div>
                </div>
                <div class="row gy-4">
                    <div class="col-sm-6">
                        <div class="ka-card p-4 h-100">
                            <h5 class="text-gold mb-3"><i class="bi bi-telephone me-2"></i>Telefon</h5>
                            <p class="text-muted mb-0">+90 555 123 45 67</p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="ka-card p-4 h-100">
                            <h5 class="text-gold mb-3"><i class="bi bi-clock me-2"></i>Çalışma Saatleri</h5>
                            @if (workingHours is null)
                            {
                                <p class="text-muted mb-0">Yükleniyor...</p>
                            }
                            else
                            {
                                @foreach (var wh in workingHours)
                                {
                                    <div class="d-flex justify-content-between text-muted small mb-1">
                                        <span>@TurkceGun(wh.DayOfWeek)</span>
                                        <span>@(wh.IsOpen ? $"{wh.StartTime:hh\\:mm} - {wh.EndTime:hh\\:mm}" : "Kapalı")</span>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="ka-form-card">
                    <h4 class="mb-3">Mesaj Gönderin</h4>
                    @if (submitted)
                    {
                        <div class="alert alert-success">Mesajınız başarıyla iletildi. Teşekkür ederiz!</div>
                    }
                    <EditForm Model="model" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label class="form-label">Ad Soyad</label>
                            <InputText class="form-control" @bind-Value="model.Name" placeholder="Adınız Soyadınız" />
                            <ValidationMessage For="@(() => model.Name)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Telefon</label>
                            <InputText class="form-control" @bind-Value="model.Phone" placeholder="05XX XXX XX XX" />
                            <ValidationMessage For="@(() => model.Phone)" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Mesajınız</label>
                            <InputTextArea class="form-control" Rows="4" @bind-Value="model.Message" placeholder="Mesajınızı yazın..." />
                            <ValidationMessage For="@(() => model.Message)" />
                        </div>
                        <button type="submit" class="btn btn-gold w-100" disabled="@sending">
                            @(sending ? "Gönderiliyor..." : "Gönder")
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    private List<WorkingHour>? workingHours;
    private readonly ContactFormModel model = new();
    private bool submitted;
    private bool sending;

    protected override async Task OnInitializedAsync()
    {
        workingHours = await Db.WorkingHours
            .OrderBy(w => w.DayOfWeek == DayOfWeek.Sunday ? 7 : (int)w.DayOfWeek)
            .ToListAsync();
    }

    private async Task HandleSubmit()
    {
        sending = true;
        Db.ContactMessages.Add(new ContactMessage
        {
            Name = model.Name,
            Phone = model.Phone,
            Message = model.Message
        });
        await Db.SaveChangesAsync();
        submitted = true;
        sending = false;
        model.Name = string.Empty;
        model.Phone = string.Empty;
        model.Message = string.Empty;
    }

    private static string TurkceGun(DayOfWeek day) => day switch
    {
        DayOfWeek.Monday => "Pazartesi",
        DayOfWeek.Tuesday => "Salı",
        DayOfWeek.Wednesday => "Çarşamba",
        DayOfWeek.Thursday => "Perşembe",
        DayOfWeek.Friday => "Cuma",
        DayOfWeek.Saturday => "Cumartesi",
        DayOfWeek.Sunday => "Pazar",
        _ => day.ToString()
    };

    private class ContactFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Ad soyad gerekli.")]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Telefon numarası gerekli.")]
        public string Phone { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Mesaj gerekli.")]
        public string Message { get; set; } = string.Empty;
    }
}
